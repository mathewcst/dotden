# Local desktop development only.
#
# Packaged dotden resolves pinned chezmoi/git binaries from app resources. In
# unpackaged dev, Electron's process.resourcesPath points at Electron's own folder
# (not this repo), so point these at local binaries — otherwise startup throws
# "Bundled chezmoi/git tools were not found".
#
# Recommended: run `pnpm --filter @dotden/desktop fetch:binaries` first, then point
# each var at the fetched binary under resources/bin/<platform>/<arch>/:
#   win32/x64     -> resources/bin/win32/x64/chezmoi.exe   + git-dist/cmd/git.exe
#   darwin|linux  -> resources/bin/<platform>/<arch>/chezmoi + git-dist/bin/git
# (A host install of either tool works too.)
#
# Copy to `.env.local` and edit for your machine. `.env.local` is git-ignored.

DOTDEN_CHEZMOI_BIN=/path/to/chezmoi
DOTDEN_GIT_BIN=/path/to/git
