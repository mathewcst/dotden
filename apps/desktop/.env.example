# Local desktop development only.
#
# Packaged dotden resolves pinned chezmoi/git binaries from app resources.
# During `pnpm --filter @dotden/desktop dev`, point these at local binaries so
# Remote preflight/init can run before packaging has copied bundled tools.
#
# Copy to `.env.local` and edit for your machine. `.env.local` is git-ignored.

DOTDEN_CHEZMOI_BIN=/path/to/chezmoi
DOTDEN_GIT_BIN=/path/to/git
