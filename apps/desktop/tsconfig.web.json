{
  "extends": "@dotden/typescript-config/vite-app.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@shared/*": ["./src/shared/*"]
    },
    // The shared DotdenApi contract links to the foundation result types
    // (PreflightResult/ConnectResult), so the renderer typecheck transitively
    // loads the pure-node foundation source. It is Electron-free (ADR 0023), so
    // adding `node` lets those files type-check WITHOUT pulling Electron into the
    // web build; `vite/client` is preserved for the renderer's own ambient types.
    "types": ["vite/client", "node"]
  },
  "include": ["src/renderer/**/*.ts", "src/renderer/**/*.tsx"]
}
