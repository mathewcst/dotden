{
  "extends": "@dotden/typescript-config/base.json",
  "compilerOptions": {
    "types": ["node", "electron-vite/node"],
    "noEmit": true
  },
  // `src/shared` holds the DotdenApi IPC contract the preload is checked against.
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    // Packaging-script tests (issue 3-19) so the gate type-checks them too; the scripts
    // themselves are plain `.mjs` Node and need no compilation.
    "scripts/**/*.ts",
    "electron.vite.config.ts"
  ]
}
