{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalPassThroughEnv": ["ELECTRON_RENDERER_URL"],
  "tasks": {
    "topo": {
      "dependsOn": ["^topo"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["out/**", "dist/**", "!out/**/cache/**"]
    },
    "check:types": {
      "dependsOn": ["topo"]
    },
    "check:lint": {
      "dependsOn": ["topo"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "package": {
      "dependsOn": ["build"],
      "cache": false
    }
  }
}
